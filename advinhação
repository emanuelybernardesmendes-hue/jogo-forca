import random

def jogar_adivinhacao():
    print("=" * 30)
    print("BEM-VINDO AO ADIVINHA-PY!")
    print("=" * 30)
    
    # O computador escolhe um número entre 1 e 100
    numero_secreto = random.randint(1, 100)
    tentativas = 0
    ganhou = False

    print("Eu pensei em um número entre 1 e 100. Consegue adivinhar?")

    while not ganhou:
        try:
            chute = int(input("\nQual o seu palpite? "))
            tentativas += 1

            if chute < 1 or chute > 100:
                print("Ei! Eu disse entre 1 e 100. Tente de novo.")
                continue

            if chute == numero_secreto:
                print(f"🎉 PARABÉNS! Você acertou em {tentativas} tentativas!")
                ganhou = True
            elif chute < numero_secreto:
                print("Muito baixo! Tente um número maior. ⬆️")
            else:
                print("Muito alto! Tente um número menor. ⬇️")
        
        except ValueError:
            print("Ops! Digite um número inteiro válido.")

    print("\nObrigado por jogar!")

if __name__ == "__main__":
    jogar_adivinhacao()
